	author = {Lee, Jong Seok and Lee, Min Hyeok and Chun, Yoon-Young and Lee, Kun Mo},
	title = {Uncertainty analysis of the water scarcity footprint based on the AWARE model considering temporal variations},
	year = {2018},
	journal = {Water (Switzerland)},
	volume = {10},
	number = {3},
	pages = {},
	doi = {10.3390/w10030341},
	url = {https://www.scopus.com/pages/publications/85044129863?origin=resultslist},
	affiliations = {Department of Environmental and Safety Engineering, Ajou University, Worldcup-ro 206, Yeongtong-gu, Suwon, 16499, South Korea; Research Institute of Science for Safety and Sustainability, National Institute of Advanced Industrial Science and Technology, 16-1 Onogawa, Tsukuba, 305-8569, Japan},
	abstract = {The purpose of this paper is to compare the degree of uncertainty of the water scarcity footprint using the Monte Carlo statistical method and block bootstrap method. Using the hydrological data of a water drainage basin in Korea, characterization factors based on the available water remaining (AWARE) model were obtained. The uncertainties of the water scarcity footprint considering temporal variations in paddy rice production in Korea were estimated. The block bootstrap method gave five-times smaller percentage uncertainty values of the model output compared to that of the two different Monte Carlo statistical method scenarios. Incorrect estimation of the probability distribution of the AWARE characterization factor model is what causes the higher uncertainty in the water scarcity footprint value calculated by the Monte Carlo statistical method in this study. This is because AWARE characterization factor values partly follows discrete distribution with extreme value on one side. Therefore, this study suggests that the block bootstrap method is a better choice in analyzing uncertainty compared to the Monte Carlo statistical method when using the AWARE model to quantify the water scarcity footprint. © 2018 by the authors.},
	author_keywords = {Block bootstrap; Characterization factor; Monte Carlo statistical method; Probability distribution; Uncertainty analysis; Water scarcity footprint},
	keywords = {Korea; Catchments; Characterization; Monte Carlo methods; Probability distributions; Statistical methods; Statistics; Available water; Block bootstraps; Characterization factors; Degree of uncertainty; Discrete distribution; Hydrological data; Temporal variation; Water scarcity; bootstrapping; crop production; data set; drainage basin; hydrological modeling; Monte Carlo analysis; numerical method; paddy field; probability; temporal variation; uncertainty analysis; Uncertainty analysis},
	correspondence_address = {K.M. Lee; Department of Environmental and Safety Engineering, Ajou University, Yeongtong-gu, Suwon, Worldcup-ro 206, 16499, South Korea; email: kunlee@ajou.ac.kr},
