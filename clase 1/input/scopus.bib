@ARTICLE{Kakraliya2018122,
	author = {Kakraliya, S.K. and Jat, H.S. and Singh, Ishwar and Sapkota, Tek B. and Singh, Love K. and Sutaliya, Jhabar M. and Sharma, Parbodh C. and Jat, R.D. and Choudhary, Meena and Lopez-Ridaura, Santiago and Jat, M.L.},
	title = {Performance of portfolios of climate smart agriculture practices in a rice-wheat system of western Indo-Gangetic plains},
	year = {2018},
