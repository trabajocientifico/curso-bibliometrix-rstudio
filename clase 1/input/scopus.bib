	title = {Assessment of physical quantity and value of natural capital in China since the 21st century based on a modified ecological footprint model},
	year = {2022},
	journal = {Science of the Total Environment},
	volume = {806},
	pages = {},
	doi = {10.1016/j.scitotenv.2021.150676},
