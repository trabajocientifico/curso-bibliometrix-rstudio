@ARTICLE{Behera2023,
	author = {Behera, Soumya Sucharita and Ojha, C.S.P. and Prasad, K. S. Hari and Dash, Sonam Sandeep},
	title = {Yield, water, and carbon footprint of rainfed rice production under the lens of mid-century climate change: a case study in the eastern coastal agro-climatic zone, Odisha, India},
	year = {2023},
	journal = {Environmental Monitoring and Assessment},
	volume = {195},
	number = {5},
