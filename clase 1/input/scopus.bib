@ARTICLE{Yi2024,
	author = {Yi, J. and Gerbens-Leenes, P.W. and Aldaya, M.M.},
	title = {Crop grey water footprints in China: The impact of pesticides on water pollution},
	year = {2024},
	journal = {Science of the Total Environment},
	volume = {935},
	pages = {},
	doi = {10.1016/j.scitotenv.2024.173464},
	url = {https://www.scopus.com/pages/publications/85193841755?origin=resultslist},
	affiliations = {Integrated Research on Energy, Environment and Society (IREES), University of Groningen, Groningen, Netherlands; Science Department, Public University of Navarre (UPNA), Pamplona, Spain; Institute for Sustainability & Food Chain Innovation (IS-FOOD), Public University of Navarra (UPNA), Pamplona, Spain},
	abstract = {Agricultural water pollution is a significant challenge in China, a rapidly growing economy with a large agricultural sector. The grey water footprint (WF) is a tool for evaluating freshwater pollution. It expresses pollution in volumetric units identifying the pollutant that theoretically needs most water to be diluted to accepted water quality standards. Previous agricultural grey WF studies focused on nitrogen (N) and phosphorus (P), some studies included pesticides. This study assesses grey WFs based on N, P and 1513 pesticide combinations for twelve main crops and two crop categories in 31 Chinese provinces. Grey WFs, including the pesticide component, are far larger than estimated before, dominating total agricultural WFs (green, blue, and grey). The total grey WF of Chinese agriculture (4,900 10<sup>9</sup> m<sup>3</sup> year<sup>−1</sup>) is determined by pesticides, while grey WFs related to N and P are 450 and 1,500 10<sup>9</sup> m<sup>3</sup> year<sup>−1</sup>, differences of a factor of eleven and three respectively. The provinces Heilongjiang, Inner Mongolia, Hebei, Henan, and Shandong are hotspots contributing 37 % to the total grey WF. A limited number of pesticides used for maize, vegetables, fruits and potato (Mancozeb a fungicide, Acetochlor a herbicide and Cypermethrin an insecticide) dominate total grey WFs, contributing 80 % to the total grey WF. Eliminating the most polluting pesticides per category and redistributing the remaining ones with a similar function but lower grey WFs reduces national water pollution from agriculture by 64 %. Only five crops, i.e. maize, potato, soybean, rice and wheat, and the two crop categories, vegetables and fruits, contribute 94 % to this reduction. Probably grey WFs could reduce even further with a second elimination and redistribution effort. This study is the first national grey WF assessment related to pesticides in agriculture. It offers valuable insights to farmers and policymakers to enhance water quality in China and beyond. © 2024},
	author_keywords = {Agriculture; Grey water footprint; Nitrogen; Pesticides; Phosphorus; Water pollution},
	keywords = {China; Agricultural pollution; Crops; Economics; Fruits; Nitrogen; Pesticides; Vegetables; Water pollution; Water quality; acetochlor; cypermethrin; fertilizer; fungicide; herbicide; mancozeb; nitrogen; pesticide; phosphorus; fresh water; insecticide; nitrogen; phosphorus; Agricultural sector; Agricultural water; Fresh water pollutions; Gray water; Gray water footprint; Heilongjiang; Pesticide combinations; Volumetrics; Water footprint; Water quality standard; agricultural development; maize; nitrogen; phosphorus; water pollution; water quality; Article; China; crop production; EC50; fruit; maize; potato; vegetable; water availability; water footprint; water pollution; water quality; agricultural worker; agriculture; article; controlled study; crop; economic aspect; Inner Mongolia; rice; soybean; water standard; wheat; Phosphorus},
	correspondence_address = {J. Yi; Integrated Research on Energy, Environment and Society (IREES), University of Groningen, Groningen, Netherlands; email: j.yi@rug.nl},
	publisher = {Elsevier B.V.},
	issn = {00489697},
	coden = {STEVA},
