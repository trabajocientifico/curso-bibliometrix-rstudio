@ARTICLE{Gai2026,
	author = {Gai, Dongsheng and Shi, Boting and Li, Haipeng and Liu, Yueyue and Shao, Xiwen and Geng, Yanqiu and Guo, Liying and Zhang, Qiang},
	title = {Multidimensional sustainability assessment of rice cultivation systems in cold regions: Trade-offs and synergies among water, carbon, energy, and economic footprints},
