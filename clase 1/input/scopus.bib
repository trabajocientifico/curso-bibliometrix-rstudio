	author = {Sreeshna, T.R. and Athira, P. and Soundharajan, B.},
	title = {Impact of Climate Change on Regional Water Availability and Demand for Agricultural Production: Application of Water Footprint Concept},
	year = {2024},
	journal = {Water Resources Management},
