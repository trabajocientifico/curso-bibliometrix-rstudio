@ARTICLE{Cheng2015422,
	author = {Cheng, K. and Yan, M. and Nayak, D. and Pan, G.X. and Smith, P. and Zheng, J.F. and Zheng, J.W.},
	title = {Carbon footprint of crop production in China: An analysis of National Statistics data},
