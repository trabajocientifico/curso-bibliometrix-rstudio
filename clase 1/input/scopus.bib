	keywords = {Agricultural robots; Chlorophyll; Conservation; Crops; Cultivation; Efficiency; Gas emissions; Greenhouse gases; Nitrogen; Nitrogen fertilizers; Optical sensors; Sustainable development; Agricultural productions; Atmospheric pollution; Crop rotation; Environmental footprints; FIRB; Nitrogen-use efficiency; System of rice intensifications; Zero tillage; Seed},
