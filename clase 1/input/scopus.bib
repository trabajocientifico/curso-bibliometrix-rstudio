	pages = {253 - 272},
	doi = {10.1007/978-981-96-0759-4_14},
	url = {https://www.scopus.com/pages/publications/105009145981?origin=resultslist},
	affiliations = {Indian Council of Agricultural Research, New Delhi, India; ICAR- Indian Institute of Pulses Research, Kanpur, India; ICAR- Indian Institute of Millets Research, Hyderabad, India},
	abstract = {The sustainability of Indian agriculture faces a myriad of challenges, including climate change impacts, declining factor productivity, depleting natural resources, soil health degradation, high energy intensiveness, and the environmental concern of residue burning. Climate change introduces unpredictable weather patterns, affecting crop yields, while input-intensive modern agricultural practices have led to natural resource degradation and declining soil fertility. Mitigating these challenges requires holistic strategies, promoting climate-resilient agriculture, efficient resource management, and sustainable practices. Pulses and millets emerge as sustainable solutions to address climate change in Indian agriculture. These crops exhibit resilience to erratic weather patterns, low water requirements, and adaptability to diverse agroclimatic conditions. Pulses enhance soil fertility and reduce the need for synthetic fertilizers, mitigating greenhouse gas (GHG) emissions. Millets, with their climate resilience and low input requirements, offer a promising alternative in the face of climate crises. Over the past decade, pulse production has seen a remarkable surge, along with a substantial increase in the cultivation area. In contrast, millet cultivation has seen a decline in both area and production. The government’s initiative to diversify away from traditional cereal crops highlights the crucial role of pulses and millets in promoting food and nutritional security, as well as sustainable agriculture. The environmental friendliness of pulses and millets is highlighted by their low carbon and water footprints. Conservation agriculture practices, cropping system diversification, and innovative approaches like the System of Millets Intensification contribute to resource conservation and ecological sustainability. Pulses and millets play a pivotal role in enhancing climate resilience, promoting biodiversity, and building a more sustainable and environmentally conscious agricultural landscape in India. © National Academy of Agricultural Sciences (if applicable) and The Author(s), under exclusive license to Springer Nature Singapore Pte Ltd. 2025.},
	author_keywords = {Biodiversity; Climate resilience; Conservation agriculture; Diversification; Rice fallow; Sustainability},
	keywords = {Climate change; Conservation; Crops; Cultivation; Fertilizers; Greenhouse gases; Soils; Sustainable agriculture; Climate resilience; Conservation agricultures; Diversification; Environment friendly; Low water; Resource-efficient; Resources environments; Rice fallow; Soil fertility; Weather patterns; Sustainable development},
	publisher = {Springer Science+Business Media},
	isbn = {978-981960759-4; 978-981960758-7},
	language = {English},
	abbrev_source_title = {Advances in Agri-Food Systems: Volume I},
