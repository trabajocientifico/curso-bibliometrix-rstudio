	keywords = {Ammonia; Crops; Cultivation; Emission control; Lakes; Life cycle; Nitrogen; Cropping systems; Double cropping; Double-cropping system; Emission factors; Nitrogen footprints; Nitrogen loss; Nitrogen management; Reactive nitrogen; Reactive nitrogen loss; Waters managements; Climate change},
