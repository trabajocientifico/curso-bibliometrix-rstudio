}

@ARTICLE{Lin2023,
	author = {Lin, Hung-Cheng and Pan, Shu-Yuan and Lin, Yu-I and Cao, Dan-Thanh Ngoc},
	title = {Enhanced biomethane production with a low carbon footprint via anaerobic co-digestion of swine wastewater with rice husk},
	year = {2023},
	journal = {Science of the Total Environment},
	volume = {891},
