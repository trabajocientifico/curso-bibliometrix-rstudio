@ARTICLE{Yang2024117,
	author = {Yang, Jun and Xiao, Zuolin and Liu, Rui and Dai, Jicai and Liu, Wenli},
	title = {Optimizing major grain crop planting structure and analysis of water use efficiency in the Sichuan Province from the perspective of water footprint; [水足迹视角下四川省主要粮食作物种植结构优化及用水效率分析]},
