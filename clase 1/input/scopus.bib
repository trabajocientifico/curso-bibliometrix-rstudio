@BOOK{Sandhu2018737,
	author = {Sandhu, Nitika and Singh, Virender and Sihag, Manvesh Kumar},
	title = {Genomic footprints uncovering abiotic stress tolerance in rice},
	year = {2018},
	journal = {Advances in Rice Research for Abiotic Stress Tolerance},
	pages = {737 - 753},
	doi = {10.1016/B978-0-12-814332-2.00036-8},
	url = {https://www.scopus.com/pages/publications/85092572844?origin=resultslist},
	affiliations = {Division of Plant Breeding, International Rice Research Institute, Metro Manila, Philippines; Indian Institute of Wheat & Barley Research, Karnal, Haryana, India; Mansinhbhai Institute of Dairy and Food Technology (MIDFT), Mehsana, Gujarat, India},
	abstract = {Changing climatic conditions, increasing population, and decreasing crop productivity are all important constraints to global food security. The abiotic stresses such as extreme temperatures (high and low), harmful radiation, high and low light intensity, water (flooding, drought, and submergence), salinity, chemical factors, excess and deficiency of essential nutrients, micronutrients, and gaseous pollutants (CO2, N2O, ozone, sulfur dioxide) are major challenges to sustainable agriculture. There is an urgent need to develop climate resilient rice crop varieties in order to ensure food security. Abiotic stress is a complex phenomenon involving a series of unpredictable factors. Plant cells displayed various morphological, physiological, and biochemical changes in order to withstand mild, medium, and severe stresses simultaneously. Exploitation of new genetic tools, techniques, and technologies will allow us to move toward the development of climate smart agriculture especially in the case of crops. Complete understanding of the physiological, biological, molecular mechanisms, identification and deployment of novel loci through marker assisted breeding, discoveries of stress-responsive genes and pathways, up- and down-regulation of genes, and the determination of function and expression patterns of the associated genes may help in designing plants with enhanced tolerance to abiotic stresses. The key aim of this chapter is to review all known abiotic stresses with aspects of genetic mechanisms involved in tolerance, to highlight the successes achieved to date, and to motivate a more critical modern thinking aligned with the development of ground-breaking systems-based approaches for enhancing rice productivity. © 2019 Elsevier Inc. All rights reserved.},
	author_keywords = {Abiotic stress; Climate; Genes; Genomic; QTls},
	publisher = {Elsevier},
	isbn = {978-012814332-2; 978-012814333-9},
	language = {English},
	abbrev_source_title = {Advances in Rice Research for Abiotic Stress Tolerance},
	type = {Book chapter},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 3}
}

