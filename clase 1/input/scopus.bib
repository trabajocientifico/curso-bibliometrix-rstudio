@ARTICLE{Jatana2025,
	author = {Jatana, Mansukh Singh and Sheoran, Parvender and Fagodiya, Ram Kishore and Kumar, Ashwani and Mann, Anita and Kumar, Parveen and Mehla, Mukesh Kumar and Kumar, Ajay and Kumar, Satyendra},
	title = {Designing an ecologically sustainable and resource-efficient rice-wheat system in the Western Indo-Gangetic Plains of India: Integrating practices of pressurized irrigation, tillage and residue management},
