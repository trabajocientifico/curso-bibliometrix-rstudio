	keywords = {Animals; Cooking; Developing countries; Food supply; Fossil fuels; Liquefied petroleum gas; Petroleum prospecting; Rural areas; Water resources; Wood products; Food consumption; Fresh water resources; Fuelwood consumption; Fuelwood production; Future prospects; Literature reviews; Percapita consumption; Research questions; Oils and fats},
