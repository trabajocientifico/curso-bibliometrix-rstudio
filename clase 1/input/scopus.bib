	keywords = {Carbon footprint; Compressive strength; Glass; High performance concrete; Lime; Portland cement; Recycling; Statistical mechanics; Water absorption; DoE; Ordinary Portland cement; Packing density; Partial replacement; Recycled glass; Recycled glass ultra-high-performance concrete; Rice-husk ash; RSM; Supplementary cementitious material; Ultra high performance; Silica fume},
