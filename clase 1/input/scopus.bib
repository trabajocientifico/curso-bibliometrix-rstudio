	author = {Ji, Yalan and Zhou, Yongjin and Li, Zhong and Feng, Kaixuan and Sun, Xueyuan and Xu, Youzun and Wu, Wenge and Zou, Huawen},
	title = {Carbon footprint research and mitigation strategies for rice-cropping systems in China: a review},
	year = {2024},
	journal = {Frontiers in Sustainable Food Systems},
	volume = {8},
