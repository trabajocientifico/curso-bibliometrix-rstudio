	author = {Brandão, Camilo Rafael Pereira and de Sousa, Inaja Francisco and Monteiro, Nathalie Barbosa Reis},
	title = {Application of the Water Footprint in the rice processing agroindustry in lower São Francisco Sergipe; [Aplicação da Pegada Hídrica na agroindústria do beneficiamento do arroz no baixo São Francisco sergipano]},
	year = {2025},
	journal = {Revista Brasileira de Geografia Fisica},
	volume = {18},
