	keywords = {China; Taihu Lake; Floods; Global warming; Greenhouse effect; Greenhouse gases; Lakes; Nitrogen oxides; Organic carbon; Productivity; Soils; Water; methane; nitrogen oxide; organic carbon; water; Bio chars; Controlled irrigations; Dissolved organic carbon; Global warming potential; Greenhouse gases emissions; Rice yield; Soil fertility; Sustainable utilization; annual variation; biochar; crop yield; dissolved organic carbon; flooding; global warming; greenhouse gas; irrigation system; methane; nitrous oxide; organic carbon; paddy field; rice; soil carbon; soil fertility; Article; carbon footprint; China; controlled study; field experiment; flooding; greenhouse effect; greenhouse gas; irrigation (agriculture); lake; priority journal; rice; soil; Irrigation},
