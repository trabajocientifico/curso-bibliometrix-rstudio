	title = {Prospects of utilizing seawater as a reaction medium for pretreatment and saccharification of rice straw},
	year = {2022},
	journal = {Chemosphere},
	volume = {293},
	pages = {},
	doi = {10.1016/j.chemosphere.2022.133528},
