	correspondence_address = {N. Akhtar; Division of Environmental Technology, School of Industrial Technology, Universiti Sains, Gelugor, Pulau Pinang, 11800, Malaysia; email: naseemamu6@gmail.com; S.A. Muhammad; Division of Environmental Technology, School of Industrial Technology, Universiti Sains, Gelugor, Pulau Pinang, 11800, Malaysia; email: syahidah.muhammad@usm.my},
