@ARTICLE{Negi2025,
	author = {Negi, Deepti and Bhadury, Punyasloke and Daverey, Achlesh},
	title = {Comparative study of Acorus calamus and Cyperus alternifolius in rice husk biochar integrated constructed wetland systems for nitrogen removal},
