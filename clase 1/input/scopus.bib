	title = {Spatial pattern of the agricultural water footprint and its environmental impact in Lake Dianchi Basin},
	year = {2015},
	journal = {Huanjing Kexue Xuebao/Acta Scientiae Circumstantiae},
	volume = {35},
	number = {11},
	pages = {3719 - 3729},
	doi = {10.13671/j.hjkxxb.2015.0503},
	url = {https://www.scopus.com/pages/publications/85014486901?origin=resultslist},
	affiliations = {College of Environmental Science and Engineering, Beijing Forestry University, Beijing, 100083, China; Yunnan Institute of Environmental Science, Kunming, 650034, China},
	abstract = {Scientific and reasonable assessment of water resources consumption and its environmental impact on the agricultural products is of great significance for regional agricultural production security and water resources rational allocation. By combining the water footprint and life cycle assessment methods, this paper analysed the spatial pattern of the water footprint of main agricultural products and its environmental impact in Lake Dianchi Basin from 2005 to 2011. The results show that the average water footprints of main crops and animal products were 4.88×10<sup>8</sup> m<sup>3</sup>·a<sup>-1</sup> and 8.97×10<sup>8</sup> m<sup>3</sup>·a<sup>-1</sup>, respectively. The total water footprints of animal products were larger than those of crop productions. The environmental impacts of water footprint of animal products on human health and ecosystem quality were higher than those of crops, whereas the environmental impact on resource consumption was lower than that of crops. Pork, rice and maize had the largest environmental impact values of water footprint. The water footprints and their environmental impacts of main agricultural products for each district in Lake Dianchi Basin were significantly different. The water footprints and the relative environmental impact of agricultural products were the highest in Songming County and Jinning County and were lower in urban areas. To assess the impact of a product on regional water sustainability, water policy should be considered from the perspectives of both water resources management and life cycle environmental impact. In a water-deficient area, the products which consume less water should be chosen, whereas the products with lower environmental impact are favored in water-rich area. © 2015, Science Press. All right reserved.},
	author_keywords = {Environmental impact; Lake Dianchi Basin; Life cycle assessment; Spatial pattern; Water footprint},
	keywords = {China; Dianchi Basin; Jinning; Yunnan; Animalia; Zea mays; agricultural application; agricultural production; environmental impact assessment; life cycle analysis; regional security; resource allocation; resource use; spatial analysis; water footprint; water resource},
	correspondence_address = {K. Huang; College of Environmental Science and Engineering, Beijing Forestry University, Beijing, 100083, China; email: huangkai@bjfu.edu.cn},
	publisher = {Science Press},
