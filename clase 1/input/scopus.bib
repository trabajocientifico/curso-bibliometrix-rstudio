@BOOK{Choudhury202567,
	author = {Choudhury, Debojit Baidya and Bebartta, Ram Prasad and Umar, Muhammad and Chauhan, Divya Singh},
	title = {Future-based sustainable grain crops},
	year = {2025},
	journal = {Sustainable Plant Foods: A Scientific Approach to Alternative Food Sources},
	pages = {67 - 82},
	doi = {10.1016/B978-0-443-31652-4.00001-5},
	url = {https://www.scopus.com/pages/publications/105026842080?origin=resultslist},
	affiliations = {Department of Food Process Engineering, National Institute of Technology Rourkela, Odisha, Rourkela, India; Department of Food, Agriculture and Bioresources, Asian Institute of Technology, Klong Luang, Thailand; Department of Food Technology, Raja Balwant Singh Engineering Technical Campus, Uttar Pradesh, Agra, India},
	abstract = {Grain crops serve as the cornerstone of global food security, supplying staple foods and crucial calorie sources for an important portion of the global population. The task of augmenting grain production hinges on enhancing crop yields without escalating the inputs of land, water, and energy. Addressing issues such as climate change, water scarcity, and the necessity for sustainable farming practices is paramount for ensuring food security and mitigating the environmental impact of grain crop production. Sustainable agriculture is tasked with the dual responsibility of addressing human health and food security concerns while minimizing its environmental footprint. Nevertheless, to satisfy the needs of a growing global population and changing dietary trends towards increased consumption of animal-based products, food production must rise by a minimum of 70% by 2050. The prospect of cultivating sustainable grain crops for the future on underutilized lands holds promise for stimulating industrial and economic growth. These future-oriented sustainable grain crops have the potential to supply the growing demand for food items and contribute to sustainable agricultural practices. This chapter delves into the realm of cereal grain crops, providing an in-depth exploration of their historical evolution, present status, and prospects, while also highlighting their pivotal role in human nutrition and physiology. It brings into focus key grains such as maize, wheat, rice, sorghum, millets, and other underexploited grain crops that form the backbone of the global food supply. In addition, the chapter ventures into the territory of lesser-known pseudo cereals like Amaranth, buckwheat, millets, and quinoa. Understanding the dietary role of these crops is instrumental in ensuring their sustainable cultivation and in enhancing food and nutrition security worldwide. © 2026 Elsevier Inc. All rights reserved..},
	author_keywords = {Amaranth; Barley; Buckwheat; Millets; Quinoa; Sorghum; Sustainability; Underutilized grains},
	keywords = {Agri-food; Cereal products; Crops; Cultivation; Environmental impact; Food security; Food supply; Grain (agricultural product); Grain growth; Industrial economics; Nutrition; Sustainable agriculture; Amaranth; Barley; Buckwheat; Food security; Global population; Grain crops; Millet; Quinoa; Sorghum; Underutilized grain; Sustainable development},
