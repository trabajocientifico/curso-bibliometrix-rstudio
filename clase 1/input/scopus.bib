	author = {Jiang, Wenzhu and Fang, Xiuqin and Huang, Zhen and Chen, Zhengdao and Xiang, Wuyan and Chen, Mojun and Yang, Shuanglei and Du, Xinglin},
	title = {Greenhouse gas emissions and agronomic performances were affected by different irrigation methods in rice field},
	year = {2014},
	journal = {Journal of Food, Agriculture and Environment},
	volume = {12},
	number = {2},
	pages = {559 - 565},
