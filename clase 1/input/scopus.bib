@BOOK{Bhatt20221,
	author = {Bhatt, Rajan and Meena, Ram Swaroop and Hossain, Akbar},
	title = {Input Use Efficiency in Rice-Wheat Cropping Systems to Manage the Footprints for Food and Environmental Security},
	year = {2022},
	journal = {Input Use Efficiency for Food and Environmental Security},
	pages = {1 - 31},
	doi = {10.1007/978-981-16-5199-1_1},
