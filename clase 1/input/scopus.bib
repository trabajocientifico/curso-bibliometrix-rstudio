@ARTICLE{Zhao2026,
	author = {Zhao, Jingwen and Wu, Linxiu and Wang, Xiaomeng and Yu, Yajuan and Huang, Kai},
	title = {High-resolution water footprints of major crops in China from cities to grids},
	year = {2026},
	journal = {Scientific Reports},
	volume = {16},
