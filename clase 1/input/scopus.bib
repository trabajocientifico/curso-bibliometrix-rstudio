@ARTICLE{Han20241426,
	author = {Han, Shun-Li and Zhang, Peng-Fei and Lu, Yuan and Zhang, Jiao-Jiao and Liu, Geng and Dai, Yan-Yan and Zhang, Lei and Guo, Li-Gang},
	title = {Optimization of Crop Planting Structure in Guizhou Based on the Water-Energy-Food Nexus; [基于水−能−粮关联关系的贵州农作物种植结构优化调整]},
	year = {2024},
	journal = {Chinese Journal of Agrometeorology},
	volume = {45},
