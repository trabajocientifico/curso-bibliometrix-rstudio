@ARTICLE{Sirimanna2022,
	author = {Sirimanna, S. and Kahathuduwa, K.K.P.N. and Prasada, D.V.P.},
	title = {Are cascade reservoir systems sustainable agroecosystems? A comparative assessment of efficiency, effectiveness and resource footprint in a Sri Lankan micro-cascade},
	year = {2022},
