@ARTICLE{Jiang201562,
	author = {Jiang, Jingyan and Chen, Linmei and Sun, Qing and Sang, Mengmeng and Huang, Yao},
	title = {Application of herbicides is likely to reduce greenhouse gas (N2O and CH4) emissions from rice-wheat cropping systems},
	year = {2015},
	journal = {Atmospheric Environment},
	volume = {107},
