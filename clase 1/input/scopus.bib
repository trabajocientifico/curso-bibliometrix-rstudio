@ARTICLE{Zhao20251322,
	author = {Zhao, Yilin and Wang, Yaxuan and Zhu, Xueqin and Tan, Bin and Wei, Xun and Wan, Xiangyuan},
	title = {Sustainable transition for cereal-based agri-food systems in China: Prospective advantages of whole-grain adoption},
	year = {2025},
	journal = {Crop Journal},
	volume = {13},
	number = {5},
	pages = {1322 - 1332},
	doi = {10.1016/j.cj.2025.06.017},
	url = {https://www.scopus.com/pages/publications/105028955808?origin=resultslist},
	affiliations = {School of Advanced Agricultural Sciences, Shunde Innovation School, University of Science and Technology Beijing, Beijing, 100083, China; Zhongzhi International Institute of Agricultural Biosciences, Beijing, 100083, China; Environmental Economics and Natural Resources Group, Wageningen University & Research, Wageningen, 6706KN, Netherlands; Academy of National Food and Strategic Reserves Administration, Beijing, 100037, China; Beijing Engineering Laboratory of Main Crop Bio-Tech Breeding, Beijing International Science and Technology Cooperation Base of Bio-Tech Breeding, Beijing Solidwill Sci-Tech Co., Ltd., Beijing, 100192, China},
	abstract = {A dietary transition from refined to whole grains would optimize grain processing, reduce food loss and emissions, and increase food nutritional contents. The results of systematical analysis and calculations in our study show that the average processing loss rate of grains including rice, wheat, and maize is approximately 4.1% in China due to the refinement, equivalent to an annual loss of around 13.3 Mt of grains. Furthermore, the refining process significantly reduces the nutritional contents of rice (51.6%), wheat flour (55.4%), and corn products (80.4%) mainly resulting from the removal of dietary fiber, minerals, and vitamins in refined grains. Replacing refined grains with whole grains in diets would lower agricultural carbon emissions by 2.7%, reducing agricultural water use by 4.3%, and saving arable land by 1,972,607 ha. Total environmental footprint could be reduced by 35% to 79% under three proposed scenarios. These findings indicate that shifting toward whole grain-based diets by Chinese consumers could reduce food losses, enhance human health, and improve environmental sustainability. This approach offers a promising strategy for transitioning towards more resilient and sustainable agri-food systems, benefiting human and planetary health. © 2025 Crop Science Society of China and Institute of Crop Science, CAAS},
	author_keywords = {Agri-Food systems; Emission reduction; Food security; Food transition; Sustainability; Whole grains},
	publisher = {KeAi Communications Co.},
