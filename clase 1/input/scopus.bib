@ARTICLE{Gao2020110,
	author = {Gao, Haiyan and Li, Wangcheng and Li, Chen and Dong, Yaping and Hao, Lu and Ma, Ji'an and Liu, Zixi and Li, Yukun},
	title = {Water Footprints of Main Crops and Their Change in Ningxia; [宁夏主要农作物生产水足迹及其变化趋势研究]},
	year = {2020},
	journal = {Journal of Irrigation and Drainage},
	volume = {39},
