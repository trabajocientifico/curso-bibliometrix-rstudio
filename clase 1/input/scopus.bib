@ARTICLE{Behera20246598,
	author = {Behera, Stuti Debapriya and Garnayak, Lalita Mohan and Behera, Biswaranjan and Behera, Basudev and Sarangi, Sukanta Kumar and Jena, Jagadish and Behera, Swosti D. and Dwibedi, Sanat K.},
	title = {Assessment of Management Practices for Improving Productivity, Profitability, and Energy-Carbon-Water Use Efficiency of Intensive Rice-toria-Sweet Corn System in Eastern India},
