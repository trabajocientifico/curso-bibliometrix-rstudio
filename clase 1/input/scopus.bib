@ARTICLE{Chen20201764,
	author = {Chen, Sheng and Wu, Mengyang and Cao, Xinchun and Guo, Xiangping},
	title = {Analysis of the characteristics and driving forces of water footprint productivity in paddy rice cultivation in China},
