@BOOK{Kane-Potaka202658,
	author = {Kane-Potaka, J. and Anitha, S. and Devi, Miruthika and Grando, Saa and Prasad, Vara},
	title = {Millets and the Environment: A Climate-Smart Solution for Sustainable Agriculture},
	year = {2026},
	journal = {Millets as Superfood: Biochemistry, Biotechnology, and Applications},
	pages = {58 - 68},
	doi = {10.1201/9781003613374-4},
	url = {https://www.scopus.com/pages/publications/105029995338?origin=resultslist},
	affiliations = {Asia-Pacifc Association of Agricultural Research Institutions (APPARI), Bangkok, Thailand; University of Saskatchewan, Saskatoon, Canada; The International Center for Agricultural Research in the Dry Areas–ICARDA, Beirut, Lebanon},
	abstract = {Agriculture, while fundamental to human sustenance, is a major contributor to environmental degradation and greenhouse gas emissions, second only to the energy sector. As climate change accelerates, with rising temperatures and increasingly erratic rainfall, the need for resilient, low-impact crops becomes urgent. Millets—nutritious, drought-tolerant, and underutilized—emerge as a promising solution for sustainable agriculture and climate adaptation. This chapter explores the multifaceted environmental benefits of millets, including their low carbon and water footprints, efficient energy use, and resilience to climatic stresses. Millets emit significantly lower greenhouse gases than rice and wheat, require 60–70% less water, and thrive in degraded soils and high temperatures up to 64°C. Their short growing cycle and natural pest resistance reduce the need for chemical inputs, minimizing ecological harm and enhancing food safety. Genetic diversity among millet varieties offers further potential for breeding climate-resilient cultivars. Diversifying cropping systems with millets can improve soil health, reduce irrigation demand, and lower greenhouse gas emissions, while increasing nutrient output. Despite their advantages, the chapter cautions against unsustainable intensification that may replicate ecological harms seen in other staple crops. The chapter underscores the importance of research, policy support, and farmer incentives to promote millets as “green energy” for the food system. Ultimately, millets offer a strategic pathway to meet global food security, nutrition, and climate goals—provided their cultivation is scaled responsibly and sustainably. © 2026 selection and editorial matter, Sadhana Singh and Santosh Kumar Upadhyay; individual chapters, the contributors.},
