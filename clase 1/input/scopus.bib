	affiliations = {Department of Life Science, National Institute of Technology Rourkela, 769008, Odisha, India; Department of Food Science and Human Nutrition, Iowa State University, 50011, Iowa, United States; Department of Biotechnology & Medical Engineering, National Institute of Technology Rourkela, 769008, Odisha, India},
	abstract = {The transition towards a bio-based economy has led to an unprecedented surge in fresh water consumption that renders biofuel a high water footprint product. The depleting fresh water resources have exacerbated the situation which necessitates the exploration of non-potable water for biorefinery purposes. In the current study, seawater is used as a plausible alternative reaction medium for pretreatment and saccharification of rice straw. Response Surface Methodology (RSM) based on Box-Behnken Design (BBD) was employed to model, predict and validate cellulose release and reducing sugar yield from rice straw subjected to microwave-NaOH pretreatment. The optimized pretreatment conditions were determined to be 8.54% substrate loading, 1.94% NaOH and 4.09 min which resulted in the maximum cellulose release of 65.43% and reducing sugar yield of 0.554 g/g. Several physico-chemical studies of the raw and pretreated biomass were carried out using bomb calorimetry, scanning electron microscopy (SEM), Fourier transform infrared (FTIR) spectroscopy, Brunauer–Emmett–Teller (BET) analysis and thermal gravimetric analysis (TGA) to examine the efficacy of pretreatment. Evidences of an apparent delignification was substantiated by the increase in surface area from 7.719 to 44.188 m<sup>2</sup> g<sup>−1</sup>and pore volume from 0.039 to 0.071 mlg<sup>−1</sup> which was consistent with the decrease in energy density and distorted surface morphology of the pretreated biomass. Further, the FTIR revealed a reduced peak in the absorption spectral bands at 1636 cm<sup>−1</sup> which confirmed the pretreatment mediated degradation of lignin and hemicellulose. This finding provides evidence on the prospects of utilizing abundantly available seawater resource as a reaction medium for sustainable biofuel production. © 2022 Elsevier Ltd},
	author_keywords = {Microwave; Pretreatment; Rice straw; Saccharification; Seawater},
	keywords = {Algae; Anatomy; Delignification; Drinking Water; Gravimetry; Saccharification; Scanning Electron Microscopy; Thermal Analysis; Cellulose; Hydrolysis; Lignin; Oryza; Seawater; Algae; Biofuels; Delignification; Fourier transform infrared spectroscopy; Morphology; Potable water; Saccharification; Scanning electron microscopy; Seawater; Sodium hydroxide; Sugars; Surface morphology; Thermogravimetric analysis; cellulose; hemicellulose; lignin; lignocellulose; sea water; sea water; Bio-based; Fresh water consumption; Fresh water resources; High water; Pre-treatments; Reaction media; Reducing sugars; Rice straws; Sugar yield; Water footprint; biofuel; chemical reaction; response surface methodology; seawater; straw; waste treatment; Article; biochemical composition; biotransformation; calorimetry; chemical composition; chemical structure; energy dispersive X ray spectroscopy; enzyme synthesis; Fourier transform infrared spectroscopy; hydrogen bond; immunoblotting; infrared spectroscopy; microwave radiation; physical chemistry; pore volume; response surface method; saccharification; scanning electron microscopy; surface area; thermogravimetry; ultrasound assisted extraction; chemistry; hydrolysis; Oryza; Cellulose},
	correspondence_address = {B. Paramasivan; Department of Biotechnology & Medical Engineering, National Institute of Technology Rourkela, 769008, India; email: biobala@nitrkl.ac.in},
