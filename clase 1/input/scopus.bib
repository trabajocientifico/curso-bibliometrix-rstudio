@ARTICLE{Linquist2018395,
	author = {Linquist, Bruce A. and Marcos, Mathias and Arlene Adviento-Borbe, M. and Anders, Merle and Harrell, Dustin and Linscombe, Steve and Reba, Michele L. and Runkle, Benjamin R.K. and Tarpley, Lee and Thomson, Allison},
	title = {Greenhouse gas emissions and management practices that affect emissions in US rice systems},
	year = {2018},
