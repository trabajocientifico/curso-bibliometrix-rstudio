@ARTICLE{Morillas20194110,
	author = {Morillas, L. and Hund, S.V. and Johnson, M.S.},
	title = {Water Use Dynamics in Double Cropping of Rainfed Upland Rice and Irrigated Melons Produced Under Drought-Prone Tropical Conditions},
	year = {2019},
	journal = {Water Resources Research},
	volume = {55},
	number = {5},
	pages = {4110 - 4127},
	doi = {10.1029/2018WR023757},
	url = {https://www.scopus.com/pages/publications/85066151930?origin=resultslist},
	affiliations = {Centre for Sustainable Food Systems, Faculty of Land and Food Systems, The University of British Columbia, Vancouver, BC, Canada; Department of Earth, Ocean and Atmospheric Sciences, The University of British Columbia, Vancouver, BC, Canada; Institute for Resources, Environment and Sustainability, The University of British Columbia, Vancouver, BC, Canada},
	abstract = {Agricultural expansion and intensification is occurring in seasonally dry regions of Central America, while droughts are intensifying due to increasing water demand and climatic change. Empirical measurements of water consumption of major crops in this region are scarce but crucial to assess agricultural water use dynamics in the light of increasing regional water conflicts. We empirically quantify total crop water use (CWU) and water footprints (WFs) of rainfed upland rice (wet season) and groundwater-irrigated melons (dry season) grown sequentially as a double cropping system, one of the major cropping systems in the seasonally dry province of Guanacaste in northwestern Costa Rica. Data for this study cover 2 years and were measured with a state-of-the-art eddy covariance water and carbon flux station. Upland rice only consumed green water (CWU<sub>green</sub> = 383 L/m<sup>2</sup>), while melons only consumed blue water (CWU<sub>blue</sub> = 177 L/m<sup>2</sup>). Irrigation was found to be 1.5 times larger than the actual melon water consumption, with better irrigation efficiencies than reported for melon farms in Brazil but slightly inferior to farms in Spain. Melon WF<sub>blue</sub> was 79 m<sup>3</sup>/t, a much lower value than global and regional estimates reported but similar to values reported for melons produced in Brazil or Spain. Upland rice WF<sub>green</sub> (681 m<sup>3</sup>/t) was reported for the first time and was proven to be much lower than flood irrigated-rice WF<sub>blue-green</sub>. Our results demonstrated lower overall water demand for upland rice-melon double crop compared to the two other major monocultures of the region (flood-irrigated rice and irrigated sugar cane). ©2019. American Geophysical Union. All Rights Reserved.},
	author_keywords = {agricultural intensification; Central America; drought; eddy covariance; seasonally dry tropics; water use efficiency},
	keywords = {Brazil; Costa Rica; Guanacaste; Spain; Cucumis; Saccharum; Crops; Drought; Efficiency; Floods; Groundwater; Irrigation; Landforms; Sugar cane; Tropics; Agricultural expansion; Agricultural intensification; Agricultural water use; Central America; Eddy covariance; Irrigation efficiency; Major cropping systems; Water use efficiency; agricultural intensification; carbon flux; double cropping; drought stress; fruit production; irrigation system; rainfed agriculture; tropical region; upland region; water use; water use efficiency; Water supply},
	correspondence_address = {L. Morillas; Centre for Sustainable Food Systems, Faculty of Land and Food Systems, The University of British Columbia, Vancouver, Canada; email: laura.morillas@ubc.ca},
	publisher = {Blackwell Publishing Ltd},
