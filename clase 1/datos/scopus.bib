	correspondence_address = {X. Du; State Key Laboratory of Efficient Utilization of Arable Land in China, Key Laboratory of Non-Point Source Pollution Control, Ministry of Agriculture and Rural Affairs, Institute of Agricultural Resources and Regional Planning, Chinese Academy of Agricultural Sciences, Beijing, 100081, China; email: duxinzhong@caas.cn},
