}

@ARTICLE{Al-Zahery2011,
	author = {Al-Zahery, Nadia and Pala, Maria and Battaglia, Vincenza and Grugni, Viola and Hamod, Mohammed A and Kashani, Baharak and Olivieri, Anna and Torroni, Antonio and Santachiara-Benerecetti, Augusta S and Semino, Ornella},
	title = {In search of the genetic footprints of Sumerians: A survey of Y-chromosome and mtDNA variation in the Marsh Arabs of Iraq},
	year = {2011},
	journal = {BMC Evolutionary Biology},
	volume = {11},
	number = {1},
	pages = {},
	doi = {10.1186/1471-2148-11-288},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-80053461917&doi=10.1186%2F1471-2148-11-288&partnerID=40&md5=fa5d3db28f3292a24972236670717fe1},
	affiliations = {Dipartimento di Genetica e Microbiologia, Universit di Pavia, 27100 Pavia, Via Ferrata 1, Italy; Department of Biotechnology, Faculty of Sciences, Baghdad University, 10001 Baghdad, Iraq; Department of Microbiology, UNESCO-MIRCEN for Marine Biotechnology, College of Fisheries, 575002 Mangalore, India; Centro Interdipartimentale Studi di Genere, Universit di Pavia, 27100 Pavia, Italy},
	abstract = {Background: For millennia, the southern part of the Mesopotamia has been a wetland region generated by the Tigris and Euphrates rivers before flowing into the Gulf. This area has been occupied by human communities since ancient times and the present-day inhabitants, the Marsh Arabs, are considered the population with the strongest link to ancient Sumerians. Popular tradition, however, considers the Marsh Arabs as a foreign group, of unknown origin, which arrived in the marshlands when the rearing of water buffalo was introduced to the region. Results: To shed some light on the paternal and maternal origin of this population, Y chromosome and mitochondrial DNA (mtDNA) variation was surveyed in 143 Marsh Arabs and in a large sample of Iraqi controls. Analyses of the haplogroups and sub-haplogroups observed in the Marsh Arabs revealed a prevalent autochthonous Middle Eastern component for both male and female gene pools, with weak South-West Asian and African contributions, more evident in mtDNA. A higher male than female homogeneity is characteristic of the Marsh Arab gene pool, likely due to a strong male genetic drift determined by socio-cultural factors (patrilocality, polygamy, unequal male and female migration rates). Conclusions: Evidence of genetic stratification ascribable to the Sumerian development was provided by the Y-chromosome data where the J1-Page08 branch reveals a local expansion, almost contemporary with the Sumerian City State period that characterized Southern Mesopotamia. On the other hand, a more ancient background shared with Northern Mesopotamia is revealed by the less represented Y-chromosome lineage J1-M267*. Overall our results indicate that the introduction of water buffalo breeding and rice farming, most likely from the Indian sub-continent, only marginally affected the gene pool of autochthonous people of the region. Furthermore, a prevalent Middle Eastern ancestry of the modern population of the marshes of southern Iraq implies that if the Marsh Arabs are descendants of the ancient Sumerians, also the Sumerians were most likely autochthonous and not of Indian or South Asian ancestry. © 2011Al-Zahery et al; licensee BioMed Central Ltd.},
	keywords = {Arabs; Chromosomes, Human, Y; DNA, Mitochondrial; Genetic Variation; Genetics, Medical; Genetics, Population; Haplotypes; Humans; Iraq; Male; Phylogeny; Euphrates River; Iraq; Mesopotamia; Tigris River; Bubalus; mitochondrial DNA; ancestry; autochthon; breeding population; cattle; chromosome; evolutionary biology; gene flow; genetic drift; homogeneity; human evolution; mitochondrial DNA; rice; wetland; Arab; article; genetic variability; genetics; haplotype; human; Iraq; male; medical genetics; phylogeny; population genetics; Y chromosome},
	correspondence_address = {O. Semino; Dipartimento di Genetica e Microbiologia, Universit di Pavia, 27100 Pavia, Via Ferrata 1, Italy; email: ornella.semino@unipv.it},
	issn = {14712148},
	pmid = {21970613},
	language = {English},
	abbrev_source_title = {BMC Evol. Biol.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 47; All Open Access; Gold Open Access; Green Open Access}
}

@ARTICLE{Islam2020,
	author = {Islam, S.M. Mofijul and Gaihre, Yam Kanta and Islam, Md. Rafiqul and Akter, Mahmuda and Al Mahmud, Abdullah and Singh, Upendra and Sander, Bjoern Ole},
	title = {Effects of water management on greenhouse gas emissions from farmers' rice fields in Bangladesh},
	year = {2020},
	journal = {Science of the Total Environment},
	volume = {734},
	pages = {},
	doi = {10.1016/j.scitotenv.2020.139382},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85084954986&doi=10.1016%2Fj.scitotenv.2020.139382&partnerID=40&md5=4bdb0a20bf7a053e5a8f68bfdf29bd2f},
	affiliations = {Soil Science Division, Bangladesh Rice Research Institute, Gazipur, Bangladesh; International Fertilizer Development Center, Kathmandu, Nepal; International Fertilizer Development Center, Dhaka, Bangladesh; International Fertilizer Development Center, Muscle Shoals, AL, United States; International Rice Research Institute, Los Baños, Philippines},
	abstract = {Alternate wetting and drying (AWD) irrigation in lowland rice cultivation increases water use efficiency and could reduce greenhouse gas (GHG) emissions compared to the farmers' practice of continuous flooding (CF). However, there is a dearth of studies on the impacts of water management on methane (CH<sub>4</sub>) and nitrous oxide (N<sub>2</sub>O) emissions in Bangladesh. Multi-location field experiments were conducted during the dry seasons of 2018 and 2019 to determine the baseline emissions of CH<sub>4</sub> and N<sub>2</sub>O from rice fields and compare the emissions from AWD irrigation and CF. CH<sub>4</sub> and N<sub>2</sub>O emissions were measured using the closed chamber technique and their concentrations were determined using a gas chromatograph. CH<sub>4</sub> and N<sub>2</sub>O emissions varied across water management schemes and sites. AWD irrigation significantly (p < 0.05) reduced cumulative CH<sub>4</sub> emissions (37%, average across sites) without affecting grain yields compared to CF. The CH<sub>4</sub> emission factor for AWD was lower (1.39 kg ha<sup>−1</sup> day<sup>−1</sup>) compared to CF (2.21 kg ha<sup>−1</sup> day<sup>−1</sup>). Although AWD irrigation increased seasonal cumulative N<sub>2</sub>O emissions by 46%, it did not offset reduced CH<sub>4</sub> emissions. AWD reduced the total global warming potential (GWP) by 36% compared to CF. Similarly, GHG intensity (GHGI) in AWD was 34% smaller compared to that in CF. Emissions varied across sites and the magnitudes of seasonal cumulative CH<sub>4</sub> and N<sub>2</sub>O emissions were higher at the Gazipur site compared to the Mymensingh site. AWD, which saves irrigation water without any yield penalty, could be considered a promising strategy to mitigate GHG emissions from rice fields in Bangladesh. © 2018 Elsevier B.V.},
	author_keywords = {Alternate wetting and drying; Bangladesh; Emission factor; farmers' practice; Greenhouse gas emissions; Lowland rice},
	keywords = {Bangladesh; Gallium compounds; Gas emissions; Global warming; Irrigation; Nitrogen oxides; Water management; Water supply; methane; nitrous oxide; Emission factors; Field experiment; Gas chromatographs; Global warming potential; Irrigation waters; Management scheme; Water use efficiency; WETTING AND DRYING; agricultural emission; emission control; gas chromatography; greenhouse gas; irrigation; methane; nitrogen dioxide; paddy field; water management; agricultural land; alternate wetting and drying irrigation; Article; Bangladesh; carbon footprint; comparative study; concentration (parameter); continuous flooding irrigation; crop management; dry season; gas chromatography; grain yield; greenhouse effect; irrigation (agriculture); physical chemistry; priority journal; seasonal variation; water management; Greenhouse gases},
	correspondence_address = {S.M.M. Islam; Soil Science Division, Bangladesh Rice Research Institute, Gazipur, Bangladesh; email: mislambrri@gmail.com},
	publisher = {Elsevier B.V.},
	issn = {00489697},
	coden = {STEVA},
	pmid = {32460078},
	language = {English},
