	author = {Istuque, Danilo Bordan and Soriano, Lourdes and Monzó, José and Borrachero, Maria Victoria and Tashima, Mauro Mitsuuchi and Payá, Jordi},
	title = {Impact of Low CO2 Footprint-Dissolution Treatment of Silica and Potassium-Rich Biomass Ashes on the Compressive Strength of Alkali-Activated Mortars},
	year = {2025},
	journal = {Sustainability (Switzerland)},
