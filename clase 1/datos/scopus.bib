	author = {Ma, Zhengbo and Bu, Rongyan and Zhou, Guopeng and Fu, Haoran and Sun, Jinxin and Liang, Ting and Cai, Cheng and Chang, Danna and Ma, Qingxu and Wu, Ji and Chadwick, David R. and Jones, Davey L. and Cao, Weidong},
	title = {Appropriately delayed flooding before rice transplanting increases net ecosystem economic benefit in the winter green manure-rice rotation system},
	year = {2024},
