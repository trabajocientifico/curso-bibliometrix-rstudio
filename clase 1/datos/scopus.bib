@ARTICLE{Ahmed2025,
	author = {Ahmed, Sharif and Kumar, Virender and Zaman, Asad Uz and Dewan, Mahbubur Rahman and Khatun, Amina and Hossain, Khaled and Singh, Sudhanshu and Timsina, Jagadish and Krupnik, Timothy J.},
	title = {Dry direct-seeded and broadcast rice: A profitable and climate-smart alternative to puddled transplanted aus rice in Bangladesh},
	year = {2025},
	journal = {Field Crops Research},
