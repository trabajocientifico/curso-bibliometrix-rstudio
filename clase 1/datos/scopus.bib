@ARTICLE{Reddy2025,
	author = {Reddy, K. Srikanth and Parihar, C.M. and Panneerselvam, P. and Sarkar, Ayan and Patra, Kiranmoy and Bharadwaj, Sneha and Sena, D.R. and Reddy, G. Sreeja and Sinha, Alok and Dhakar, Rajkumar and Kumar, Virender and Nayak, Hari Sankar},
