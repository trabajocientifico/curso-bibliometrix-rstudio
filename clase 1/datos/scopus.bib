@ARTICLE{Chu2024,
	author = {Chu, Hao and Wu, Cui and Wang, Guixia and Lang, Yu and Aynalem, Mezgebu},
	title = {Coupling Coordination Evaluation of Water and Soil Resource Matching and Grain Production, and Analysis of Obstacle Factors in a Typical Black Soil Region of Northeast China},
