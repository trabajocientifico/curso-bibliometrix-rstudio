@ARTICLE{Kumar2023,
	author = {Kumar, Arun and Saini, Kulvir Singh and Dasila, Hemant and Kumar, Rakesh and Devi, Kavita and Bisht, Yashpal Singh and Yadav, Manish and Kothiyal, Shivani and Chilwal, Aaradhana and Maithani, Damini and Kaushik, Prashant},
	title = {Sustainable Intensification of Cropping Systems under Conservation Agriculture Practices: Impact on Yield, Productivity and Profitability of Wheat},
