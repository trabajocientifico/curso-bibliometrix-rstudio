@ARTICLE{Yvon-Durocher2014488,
	author = {Yvon-Durocher, Gabriel and Allen, Andrew P. and Bastviken, David and Conrad, Ralf and Gudasz, Cristian and St-Pierre, Annick and Thanh-Duc, Nguyen and Del Giorgio, Paul A.},
