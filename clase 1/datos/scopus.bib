	keywords = {Gangetic Plain; India; Triticum aestivum; Vigna radiata var. radiata; carbon sequestration; crop residue; emission inventory; fertilizer application; global warming; greenhouse gas; hypothesis testing; legume; methane; nitrous oxide; rice; sustainability; tillage; water footprint; wheat},
