	language = {English},
	abbrev_source_title = {Front. Sustain. food Syst.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 23; All Open Access; Gold Open Access; Green Open Access}
}

@ARTICLE{Jin20236044,
	author = {Jin, Zhaoqiang and Mu, Yixue and Li, Yusheng and Nie, Lixiao},
