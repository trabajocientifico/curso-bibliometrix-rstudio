}

@ARTICLE{Moe2024,
	author = {Moe, Myint Myat and Bunyasiri, Isriya and Sirisupluxna, Prapinwadee},
	title = {Quantifying and Comparing Greenhouse Gas Emissions in Monsoon Rice Production: A Comprehensive Analysis of Transplanting and Broadcasting Sowing Methods in Myanmar},
	year = {2024},
	journal = {Open Agriculture Journal},
	volume = {18},
	pages = {},
	doi = {10.2174/0118743315290024240122052257},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85185692958&doi=10.2174%2F0118743315290024240122052257&partnerID=40&md5=518aa426dc8a07ce6cc01dbd1a0f08dc},
	affiliations = {Department of Agricultural and Resource Economics, Faculty of Economics, Kasetsart University, Bangkok, 10900, Thailand; Department of Agricultural Economics, Yezin Agricultural University, Nay Pyi Taw, 15013, Myanmar},
	abstract = {Introduction: Rice is a staple food, an economic crop, and the second-highest source of greenhouse gas (GHG) emissions in the agricultural sector in Myanmar. To develop the rice sector in a sustainable way, this study aimed to determine the comparative GHG emissions between the two major sowing methods used in monsoon rice production. Methods: Next, comparative GHG emissions analysis was done by using the Student t-test. This study first quantified GHG emissions from land preparation to straw burning by using emission factors for agricultural inputs and the formulation, default values, and scaling factors of a carbon footprint calculator customized for rice products (CF-Rice). Results: Soil and water management was the largest contributor among the management practices in monsoon rice production and accounted for 64.8% of the total GHG emissions. At 4,479.5 kg CO<sub>2</sub> eq. ha<sup>-1</sup>, GHG emissions from the broadcasting (BC) method were significantly higher than those from the transplanting (TP) method. Conclusion: Therefore, the TP method is a better sowing technique than the BC method for reducing GHG emissions without reducing grain yield. © 2024 The Author(s). Published by Bentham Open.},
	author_keywords = {Broadcasting; Crop; Greenhouse gas emissions; Rice yield; Sowing methods; Transplanting},
	correspondence_address = {M.M. Moe; Department of Agricultural and Resource Economics, Faculty of Economics, Kasetsart University, Bangkok, 10900, Thailand; email: myintmyat.m@ku.th},
	publisher = {Bentham Science Publishers},
	issn = {18743315},
	language = {English},
	abbrev_source_title = {Open Agric. J.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 2; All Open Access; Gold Open Access}
