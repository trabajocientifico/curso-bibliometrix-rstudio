	keywords = {Carbon; Clay; Compressive strength; Durability; Hemp; Kaolin; Sodium compounds; Soil mechanics; Soil testing; Stabilization; Thawing; Carbon index; Freeze-thaw cycles; Freeze-thaw tests; Geopolymer; Kaolin clay; Rice-husk ash; Sodium metasilicate; Soil stabilization; Stabilization of soil; Unconfined compressive strength; Geopolymers; Hemp fibers},
	correspondence_address = {B. Aksu Alcan; Department of Civil Engineering, Kafkas University, Kars, 36100, Turkey; email: bilge.aksu@kafkas.edu.tr},
