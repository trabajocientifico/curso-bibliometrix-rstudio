@ARTICLE{Lovat2025,
	author = {Lovat, Samuel J. and Noor, Elad and Milo, Ron},
	title = {Vertical farming limitations and potential demonstrated by back-of-the-envelope calculations},
	year = {2025},
	journal = {Plant Physiology},
	volume = {198},
