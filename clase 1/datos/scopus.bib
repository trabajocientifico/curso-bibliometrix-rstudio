	keywords = {Atmospheric thermodynamics; Carbon; Climatology; Forestry; Location; Tropics; Coniferous plantations; Eddy covariance; Eddy covariance measurements; Footprint climatology; Fraction of target vegetation type; Sensor location; Sensor location bias; Spatial representativeness; Subtropical coniferous plantation; Vegetation type; Vegetation},
	correspondence_address = {H. Wang; School of Ecology and Nature Conservation, Beijing Forestry University, Beijing, 100083, China; email: wanghs@bjfu.edu.cn},
